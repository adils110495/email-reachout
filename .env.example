APP_NAME="AI Client Finder"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cold_email_db
DB_USERNAME=sail
DB_PASSWORD=password

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Session
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=redis
QUEUE_RETRY_AFTER=90

# Mail (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="outreach@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# SerpAPI — Google Search API (100 free searches/month)
# Sign up & get key at: https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Outreach settings
SENDER_NAME="Your Name"
SENDER_COMPANY="Your Company"
EMAIL_DELAY_MIN=30
EMAIL_DELAY_MAX=60

# IMAP — copy sent emails to Sent folder

IMAP_HOST=imap.hostinger.com
IMAP_USERNAME=info@heservices.in
IMAP_PASSWORD=Heservices@2024
IMAP_FROM_FOLDER=INBOX
IMAP_FOLDER=INBOX.Sent
IMAP_PORT=993
IMAP_PROTOCOL=ssl

# Docker ports
APP_PORT=8080
DB_PORT_EXTERNAL=3306
REDIS_PORT_EXTERNAL=6379
PMA_PORT=8081